generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Owner {
  id         Int     @id @default(autoincrement())
  dni        String  @unique
  name       String
  middleName String
  lastName   String?
  phone      String?
  email      String?
  farms      Farm[]
}

model Farm {
  id       Int      @id @default(autoincrement())
  regaCode String   @unique
  name     String?
  address  String
  ownerId  Int
  owner    Owner    @relation(fields: [ownerId], references: [id])
  animals  Animal[]
}

model Animal {
  id        Int              @id @default(autoincrement())
  crotal    String           @unique
  name      String?
  species   String
  sex       String
  birthDate DateTime
  farmId    Int
  farm      Farm             @relation(fields: [farmId], references: [id])
  records   ClinicalRecord[]
}

model ClinicalRecord {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  severity  String
  diagnosis String   @db.Text
  treatment String?  @db.Text
  animalId  Int
  animal    Animal   @relation(fields: [animalId], references: [id])
}
