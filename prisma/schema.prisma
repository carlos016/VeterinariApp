generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Owner {
  id             Int         @id @default(autoincrement())
  dni            String      @unique
  firstName      String      // Nombre
  firstLastName  String      // Primer Apellido
  secondLastName String?     // Segundo Apellido (Opcional, algunos extranjeros no tienen)
  phone          String?
  email          String?
  farms          Ownership[]
}

model Farm {
  id        Int         @id @default(autoincrement())
  regaCode  String      @unique
  name      String?
  address   String
  owners    Ownership[]
  animals   Animal[]
}

model Ownership {
  ownerId Int
  farmId  Int
  owner   Owner @relation(fields: [ownerId], references: [id])
  farm    Farm  @relation(fields: [farmId], references: [id])

  @@id([ownerId, farmId])
}

model Animal {
  id        Int      @id @default(autoincrement())
  crotal    String   @unique
  name      String?
  species   String
  sex       String
  birthDate DateTime
  farmId    Int
  farm      Farm     @relation(fields: [farmId], references: [id])
  records   ClinicalRecord[]
}

model ClinicalRecord {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  severity  String
  diagnosis String   @db.Text
  treatment String?  @db.Text
  animalId  Int
  animal    Animal   @relation(fields: [animalId], references: [id])
}